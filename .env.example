# DreamGate 环境变量示例（复制为 .env 并填入真实值）

# ===== 降级开关（前端可见，VITE_ 前缀）=====
# 第 12 天自检后可设为 true 触发降级，保 P0 闭环
VITE_DEGRADE_MOBILE_2_5D=false
VITE_DEGRADE_SHARE_CARD_3D=false
VITE_DEGRADE_FOG_SHADER=false
VITE_DEGRADE_DESKTOP_3D=false

# ===== AI 服务（边缘函数用，不入前端包）=====
# SiliconFlow 免费大模型 API Key（https://siliconflow.cn 注册获取，有免费额度）
# 仅在 api/llm.ts 边缘函数中读取，前端不暴露
SILICONFLOW_API_KEY=

# ===== gpt-image 图像升级（可选，改善画面质量）=====
# OpenAI Key，仅在 api/img.ts 边缘函数读取，前端不暴露；不填则前端自动回退 Pollinations → 种子图
OPENAI_API_KEY=
# 图像模型，默认 gpt-image-1（如用更新版填此处）
# OPENAI_IMAGE_MODEL=gpt-image-1
# 前端开关：设为 true 才会尝试走 /api/img（gpt-image）；默认 false 用 Pollinations
VITE_USE_GPT_IMAGE=false

# ===== 可选升级路径（复赛用，初赛留空）=====
# VOLCENGINE_API_KEY=
# DOUBAO_API_KEY=
